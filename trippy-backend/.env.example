# Supabase — get these from supabase.com > Your Project > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# AviationStack API — for advance flight scheduling (aviationstack.com > Dashboard)
AVIATIONSTACK_API_KEY=your_key_here

# Amadeus API — FREE future flight schedules (developers.amadeus.com > My Apps)
# 2,000 free production calls/month. Used for future-date lookups only.
AMADEUS_CLIENT_ID=your_client_id_here
AMADEUS_CLIENT_SECRET=your_client_secret_here

# FlightRadar24 API — for day-of flights & live tracking (fr24api.flightradar24.com > Key Management)
FR24_API_KEY=your_key_here

# SNCF/Navitia API — for French train lookups (numerique.sncf.com)
# Optional — SNCF lookup won't work without this, but Amtrak & DB work without keys
SNCF_API_KEY=your_key_here

# Google Places API — get from console.cloud.google.com
GOOGLE_PLACES_API_KEY=your_key_here

# Server
PORT=3001

# CORS — your React dev server URL
FRONTEND_URL=http://localhost:5173
