# Supabase — get these from supabase.com > Your Project > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# AviationStack — get from aviationstack.com
AVIATIONSTACK_API_KEY=your_key_here

# SNCF (French Railways) — get from numerique.sncf.com/startup/api
# Used for real-time TGV, TER, Intercités lookups via the Navitia API
SNCF_API_KEY=your_key_here

# Deutsche Bahn — register at developers.deutschebahn.com, subscribe to "Timetables" API
# DB_CLIENT_ID is the Client ID, DB_API_KEY is the Client Secret (shown once on creation)
# Rate limit: 20 req/min. Used for real-time ICE, IC, EC, RE lookups via the Timetables v1 API.
DB_CLIENT_ID=your_client_id_here
DB_API_KEY=your_client_secret_here

# Server
PORT=3001

# CORS — your brother's React dev server URL
FRONTEND_URL=http://localhost:5173
