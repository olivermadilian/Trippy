# Supabase — get these from supabase.com > Your Project > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# AviationStack — get from aviationstack.com
AVIATIONSTACK_API_KEY=your_key_here

# SNCF (French Railways) — get from numerique.sncf.com/startup/api
# Used for real-time TGV, TER, Intercités lookups via the Navitia API
SNCF_API_KEY=your_key_here

# Deutsche Bahn — no API key required
# Uses the public transport.rest wrapper: https://v6.db.transport.rest

# Server
PORT=3001

# CORS — your brother's React dev server URL
FRONTEND_URL=http://localhost:5173
